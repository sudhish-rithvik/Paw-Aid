# ─────────────────────────────────────────────────────────────────────────────
# PAW-AID Backend — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (e.g. https://xyzxyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key — bypasses Row-Level-Security; NEVER expose to the client
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── HuggingFace Inference API ─────────────────────────────────────────────────
# API token from https://huggingface.co/settings/tokens
HF_API_KEY=hf_...

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Absolute path to your Firebase service account JSON file.
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# ── Brevo (formerly Sendinblue) ───────────────────────────────────────────────
# API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# "From" email address used for transactional emails
BREVO_FROM_EMAIL=no-reply@paw-aid.app

# ── Routing / Geocoding ───────────────────────────────────────────────────────
# OpenRouteService API key from https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# ── Application ───────────────────────────────────────────────────────────────
# Secret key used for signing internal tokens (generate with: openssl rand -hex 32)
APP_SECRET_KEY=changeme_generate_a_strong_random_secret

# Public URL of this backend (used for Supabase Storage URL construction etc.)
BACKEND_URL=http://localhost:8000

# Directory where uploaded files are stored locally (relative to project root)
UPLOAD_DIR=uploads

# ── Demo / Development Mode ───────────────────────────────────────────────────
# Set to true to run without external API keys; all AI calls return mock data.
DEMO_MODE=false
